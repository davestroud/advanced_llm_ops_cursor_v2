    \PYG{c+c1}{\PYGZsh{} Create a test script}
    \PYG{n}{test\PYGZus{}script} \PYG{o}{=} \PYG{n}{output\PYGZus{}dir\PYGZus{}path} \PYG{o}{/} \PYG{l+s+s2}{\PYGZdq{}test\PYGZus{}inference.py\PYGZdq{}}
    \PYG{n}{test\PYGZus{}script}\PYG{o}{.}\PYG{n}{write\PYGZus{}text}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+s2}{import torch}
\PYG{l+s+s2}{from transformers import AutoModelForCausalLM, AutoTokenizer}

\PYG{l+s+s2}{model = AutoModelForCausalLM.from\PYGZus{}pretrained(\PYGZdq{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{model\PYGZus{}path}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{})}
\PYG{l+s+s2}{tokenizer = AutoTokenizer.from\PYGZus{}pretrained(\PYGZdq{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{model\PYGZus{}path}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{})}

\PYG{l+s+s2}{prompts = }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{test\PYGZus{}prompts}\PYG{l+s+si}{\PYGZcb{}}

\PYG{l+s+s2}{for prompt in prompts:}
\PYG{l+s+s2}{    inputs = tokenizer(prompt, return\PYGZus{}tensors=\PYGZdq{}pt\PYGZdq{}).to(\PYGZdq{}cuda\PYGZdq{})}
\PYG{l+s+s2}{    outputs = model.generate(**inputs, max\PYGZus{}length=512)}
\PYG{l+s+s2}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Run profiling}
