                \PYG{n}{bottleneck\PYGZus{}kernels}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{kernel\PYGZus{}name}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Extract memory bandwidth}
    \PYG{n}{memory\PYGZus{}bandwidth} \PYG{o}{=} \PYG{n}{stats}\PYG{o}{.}\PYG{n}{get}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Memory Bandwidth\PYGZdq{}}\PYG{p}{,} \PYG{p}{\PYGZob{}\PYGZcb{})}\PYG{o}{.}\PYG{n}{get}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Average\PYGZdq{}}\PYG{p}{,} \PYG{l+m+mi}{0}\PYG{p}{)}

