\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{compare\PYGZus{}profiles}\PYG{p}{(}
    \PYG{n}{baseline\PYGZus{}report}\PYG{p}{:} \PYG{n+nb}{str}\PYG{p}{,}
    \PYG{n}{optimized\PYGZus{}report}\PYG{p}{:} \PYG{n+nb}{str}
\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{Dict}\PYG{p}{[}\PYG{n+nb}{str}\PYG{p}{,} \PYG{n+nb}{float}\PYG{p}{]:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Compare two profiling reports to measure optimization impact.}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        baseline\PYGZus{}report: Path to baseline .nsys\PYGZhy{}rep file}
\PYG{l+s+sd}{        optimized\PYGZus{}report: Path to optimized .nsys\PYGZhy{}rep file}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{        Dictionary with improvement metrics}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{baseline} \PYG{o}{=} \PYG{n}{analyze\PYGZus{}nsys\PYGZus{}report}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}report}\PYG{p}{)}
    \PYG{n}{optimized} \PYG{o}{=} \PYG{n}{analyze\PYGZus{}nsys\PYGZus{}report}\PYG{p}{(}\PYG{n}{optimized\PYGZus{}report}\PYG{p}{)}

    \PYG{n}{total\PYGZus{}time\PYGZus{}baseline} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}\PYG{n}{baseline}\PYG{o}{.}\PYG{n}{kernel\PYGZus{}time\PYGZus{}ms}\PYG{o}{.}\PYG{n}{values}\PYG{p}{())}
    \PYG{n}{total\PYGZus{}time\PYGZus{}optimized} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}\PYG{n}{optimized}\PYG{o}{.}\PYG{n}{kernel\PYGZus{}time\PYGZus{}ms}\PYG{o}{.}\PYG{n}{values}\PYG{p}{())}

    \PYG{n}{speedup} \PYG{o}{=} \PYG{n}{total\PYGZus{}time\PYGZus{}baseline} \PYG{o}{/} \PYG{n}{total\PYGZus{}time\PYGZus{}optimized} \PYG{k}{if} \PYG{n}{total\PYGZus{}time\PYGZus{}optimized} \PYG{o}{\PYGZgt{}} \PYG{l+m+mi}{0} \PYG{k}{else} \PYG{l+m+mf}{1.0}

    \PYG{k}{return} \PYG{p}{\PYGZob{}}
        \PYG{l+s+s2}{\PYGZdq{}speedup\PYGZdq{}}\PYG{p}{:} \PYG{n}{speedup}\PYG{p}{,}
        \PYG{l+s+s2}{\PYGZdq{}baseline\PYGZus{}total\PYGZus{}ms\PYGZdq{}}\PYG{p}{:} \PYG{n}{total\PYGZus{}time\PYGZus{}baseline}\PYG{p}{,}
