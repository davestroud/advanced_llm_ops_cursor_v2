            \PYG{n}{duration\PYGZus{}ms} \PYG{o}{=} \PYG{n}{kernel}\PYG{o}{.}\PYG{n}{get}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Duration\PYGZdq{}}\PYG{p}{,} \PYG{l+m+mi}{0}\PYG{p}{)} \PYG{o}{/} \PYG{l+m+mf}{1e6}  \PYG{c+c1}{\PYGZsh{} Convert to ms}
