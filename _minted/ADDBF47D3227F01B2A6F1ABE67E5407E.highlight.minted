        \PYG{n}{command}\PYG{o}{=}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}python\PYGZdq{}}\PYG{p}{,} \PYG{n+nb}{str}\PYG{p}{(}\PYG{n}{test\PYGZus{}script}\PYG{p}{)],}
        \PYG{n}{output\PYGZus{}file}\PYG{o}{=}\PYG{n+nb}{str}\PYG{p}{(}\PYG{n}{report\PYGZus{}file}\PYG{p}{),}
        \PYG{n}{duration\PYGZus{}seconds}\PYG{o}{=}\PYG{l+m+mi}{60}
    \PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Analyze results}
    \PYG{n}{result} \PYG{o}{=} \PYG{n}{analyze\PYGZus{}nsys\PYGZus{}report}\PYG{p}{(}\PYG{n+nb}{str}\PYG{p}{(}\PYG{n}{report\PYGZus{}file}\PYG{p}{))}

