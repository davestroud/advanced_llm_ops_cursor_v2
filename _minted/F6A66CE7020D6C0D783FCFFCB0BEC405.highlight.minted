\PYG{c+c1}{\PYGZsh{} referenced above.  Sketch of one rule (full ConfigMap in companion repo):}
\PYG{n+nt}{apiVersion}\PYG{p}{:}\PYG{+w}{ }\PYG{l+lScalar+lScalarPlain}{v1}
\PYG{n+nt}{kind}\PYG{p}{:}\PYG{+w}{ }\PYG{l+lScalar+lScalarPlain}{ConfigMap}
\PYG{n+nt}{metadata}\PYG{p}{:}\PYG{+w}{ }\PYG{p+pIndicator}{\PYGZob{}}\PYG{n+nt}{ name}\PYG{p}{:}\PYG{+w}{ }\PYG{n+nv}{adapter\PYGZhy{}config}\PYG{p+pIndicator}{,}\PYG{n+nt}{ namespace}\PYG{p}{:}\PYG{+w}{ }\PYG{n+nv}{kube\PYGZhy{}system}\PYG{+w}{ }\PYG{p+pIndicator}{\PYGZcb{}}
\PYG{n+nt}{data}\PYG{p}{:}
\PYG{+w}{  }\PYG{n+nt}{config.yaml}\PYG{p}{:}\PYG{+w}{ }\PYG{p+pIndicator}{|}
\PYG{+w}{    }\PYG{n+no}{rules:}
\PYG{+w}{    }\PYG{n+no}{\PYGZhy{} seriesQuery: \PYGZsq{}ishtar\PYGZus{}token\PYGZus{}demand\PYGZus{}rate\PYGZob{}namespace!=\PYGZdq{}\PYGZdq{},pod!=\PYGZdq{}\PYGZdq{}\PYGZcb{}\PYGZsq{}}
\PYG{+w}{      }\PYG{n+no}{resources: \PYGZob{} overrides: \PYGZob{} namespace: \PYGZob{} resource: \PYGZdq{}namespace\PYGZdq{} \PYGZcb{},}
\PYG{+w}{                                }\PYG{n+no}{pod:       \PYGZob{} resource: \PYGZdq{}pod\PYGZdq{} \PYGZcb{} \PYGZcb{} \PYGZcb{}}
\PYG{+w}{      }\PYG{n+no}{name: \PYGZob{} matches: \PYGZdq{}\PYGZca{}ishtar\PYGZus{}token\PYGZus{}demand\PYGZus{}rate\PYGZdq{}, as: \PYGZdq{}token\PYGZus{}demand\PYGZus{}rate\PYGZdq{} \PYGZcb{}}
\PYG{+w}{      }\PYG{n+no}{metricsQuery: \PYGZsq{}sum(rate(\PYGZlt{}\PYGZlt{}.Series\PYGZgt{}\PYGZgt{}\PYGZob{}\PYGZlt{}\PYGZlt{}.LabelMatchers\PYGZgt{}\PYGZgt{}\PYGZcb{}[2m]))}
\PYG{+w}{                     }\PYG{n+no}{by (\PYGZlt{}\PYGZlt{}.GroupBy\PYGZgt{}\PYGZgt{})\PYGZsq{}}
\PYG{+w}{    }\PYG{n+no}{\PYGZsh{} ... analogous rules for request\PYGZus{}queue\PYGZus{}depth (avg), p95\PYGZus{}ttft\PYGZus{}ms}
\PYG{+w}{    }\PYG{n+no}{\PYGZsh{}     (histogram\PYGZus{}quantile 0.95 over 5m), and gpu\PYGZus{}utilization\PYGZus{}percent (avg).}
