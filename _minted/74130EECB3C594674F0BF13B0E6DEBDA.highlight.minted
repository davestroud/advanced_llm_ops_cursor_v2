\begin{MintedVerbatim}[commandchars=\\\{\}]
\PYG{c+ch}{\PYGZsh{}!/usr/bin/env python3}
\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{CI gate implementation with statistical control for LLM evaluation.}
\PYG{l+s+sd}{Implements paired bootstrap for continuous metrics and McNemar\PYGZsq{}s test}
\PYG{l+s+sd}{for binary safety metrics.}
\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}

\PYG{k+kn}{import}\PYG{+w}{ }\PYG{n+nn}{numpy}\PYG{+w}{ }\PYG{k}{as}\PYG{+w}{ }\PYG{n+nn}{np}
\PYG{k+kn}{from}\PYG{+w}{ }\PYG{n+nn}{scipy}\PYG{+w}{ }\PYG{k+kn}{import} \PYG{n}{stats}
\PYG{k+kn}{from}\PYG{+w}{ }\PYG{n+nn}{typing}\PYG{+w}{ }\PYG{k+kn}{import} \PYG{n}{Tuple}\PYG{p}{,} \PYG{n}{List}\PYG{p}{,} \PYG{n}{Dict}
\PYG{k+kn}{from}\PYG{+w}{ }\PYG{n+nn}{dataclasses}\PYG{+w}{ }\PYG{k+kn}{import} \PYG{n}{dataclass}

\PYG{n+nd}{@dataclass}
\PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{GateResult}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Result of a CI gate check\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{passed}\PYG{p}{:} \PYG{n+nb}{bool}
    \PYG{n}{metric\PYGZus{}name}\PYG{p}{:} \PYG{n+nb}{str}
    \PYG{n}{baseline\PYGZus{}mean}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{candidate\PYGZus{}mean}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{improvement}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{confidence\PYGZus{}interval}\PYG{p}{:} \PYG{n}{Tuple}\PYG{p}{[}\PYG{n+nb}{float}\PYG{p}{,} \PYG{n+nb}{float}\PYG{p}{]}
    \PYG{n}{p\PYGZus{}value}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{message}\PYG{p}{:} \PYG{n+nb}{str}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{paired\PYGZus{}bootstrap\PYGZus{}test}\PYG{p}{(}
    \PYG{n}{baseline\PYGZus{}scores}\PYG{p}{:} \PYG{n}{List}\PYG{p}{[}\PYG{n+nb}{float}\PYG{p}{],}
    \PYG{n}{candidate\PYGZus{}scores}\PYG{p}{:} \PYG{n}{List}\PYG{p}{[}\PYG{n+nb}{float}\PYG{p}{],}
    \PYG{n}{confidence\PYGZus{}level}\PYG{p}{:} \PYG{n+nb}{float} \PYG{o}{=} \PYG{l+m+mf}{0.95}\PYG{p}{,}
    \PYG{n}{n\PYGZus{}bootstrap}\PYG{p}{:} \PYG{n+nb}{int} \PYG{o}{=} \PYG{l+m+mi}{10000}\PYG{p}{,}
    \PYG{n}{min\PYGZus{}improvement}\PYG{p}{:} \PYG{n+nb}{float} \PYG{o}{=} \PYG{l+m+mf}{0.5}
\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{GateResult}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Paired bootstrap test for continuous metrics.}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        baseline\PYGZus{}scores: Scores from baseline version}
\PYG{l+s+sd}{        candidate\PYGZus{}scores: Scores from candidate version}
\PYG{l+s+sd}{        confidence\PYGZus{}level: Confidence level for CI}
\PYG{l+s+sd}{        n\PYGZus{}bootstrap: Number of bootstrap samples}
\PYG{l+s+sd}{        min\PYGZus{}improvement: Minimum improvement required}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{        GateResult indicating whether gate passed}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{k}{if} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}scores}\PYG{p}{)} \PYG{o}{!=} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{candidate\PYGZus{}scores}\PYG{p}{):}
        \PYG{k}{raise} \PYG{n+ne}{ValueError}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Baseline and candidate must have same length\PYGZdq{}}\PYG{p}{)}

    \PYG{n}{n} \PYG{o}{=} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}scores}\PYG{p}{)}
    \PYG{n}{differences} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{array}\PYG{p}{(}\PYG{n}{candidate\PYGZus{}scores}\PYG{p}{)} \PYG{o}{\PYGZhy{}} \PYG{n}{np}\PYG{o}{.}\PYG{n}{array}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}scores}\PYG{p}{)}
    \PYG{n}{mean\PYGZus{}diff} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{differences}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Bootstrap sampling}
    \PYG{n}{bootstrap\PYGZus{}means} \PYG{o}{=} \PYG{p}{[]}
    \PYG{k}{for} \PYG{n}{\PYGZus{}} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{n\PYGZus{}bootstrap}\PYG{p}{):}
        \PYG{n}{indices} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{random}\PYG{o}{.}\PYG{n}{choice}\PYG{p}{(}\PYG{n}{n}\PYG{p}{,} \PYG{n}{size}\PYG{o}{=}\PYG{n}{n}\PYG{p}{,} \PYG{n}{replace}\PYG{o}{=}\PYG{k+kc}{True}\PYG{p}{)}
        \PYG{n}{bootstrap\PYGZus{}diff} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{differences}\PYG{p}{[}\PYG{n}{indices}\PYG{p}{])}
        \PYG{n}{bootstrap\PYGZus{}means}\PYG{o}{.}\PYG{n}{append}\PYG{p}{(}\PYG{n}{bootstrap\PYGZus{}diff}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Calculate confidence interval}
    \PYG{n}{alpha} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{confidence\PYGZus{}level}
    \PYG{n}{lower\PYGZus{}bound} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{percentile}\PYG{p}{(}\PYG{n}{bootstrap\PYGZus{}means}\PYG{p}{,} \PYG{l+m+mi}{100} \PYG{o}{*} \PYG{n}{alpha} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{)}
    \PYG{n}{upper\PYGZus{}bound} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{percentile}\PYG{p}{(}\PYG{n}{bootstrap\PYGZus{}means}\PYG{p}{,} \PYG{l+m+mi}{100} \PYG{o}{*} \PYG{p}{(}\PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{alpha} \PYG{o}{/} \PYG{l+m+mi}{2}\PYG{p}{))}

    \PYG{c+c1}{\PYGZsh{} Gate logic: CI must exclude zero AND improvement \PYGZgt{}= threshold}
    \PYG{n}{ci\PYGZus{}excludes\PYGZus{}zero} \PYG{o}{=} \PYG{p}{(}\PYG{n}{lower\PYGZus{}bound} \PYG{o}{\PYGZgt{}} \PYG{l+m+mi}{0}\PYG{p}{)} \PYG{o+ow}{or} \PYG{p}{(}\PYG{n}{upper\PYGZus{}bound} \PYG{o}{\PYGZlt{}} \PYG{l+m+mi}{0}\PYG{p}{)}
    \PYG{n}{meets\PYGZus{}improvement} \PYG{o}{=} \PYG{n}{mean\PYGZus{}diff} \PYG{o}{\PYGZgt{}=} \PYG{n}{min\PYGZus{}improvement}

    \PYG{n}{passed} \PYG{o}{=} \PYG{n}{ci\PYGZus{}excludes\PYGZus{}zero} \PYG{o+ow}{and} \PYG{n}{meets\PYGZus{}improvement}

    \PYG{n}{message} \PYG{o}{=} \PYG{p}{(}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Mean improvement: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{mean\PYGZus{}diff}\PYG{l+s+si}{:}\PYG{l+s+s2}{.3f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ \PYGZdq{}}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}(CI: [}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{lower\PYGZus{}bound}\PYG{l+s+si}{:}\PYG{l+s+s2}{.3f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{, }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{upper\PYGZus{}bound}\PYG{l+s+si}{:}\PYG{l+s+s2}{.3f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{]). \PYGZdq{}}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Required: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{min\PYGZus{}improvement}\PYG{l+s+si}{:}\PYG{l+s+s2}{.3f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{. \PYGZdq{}}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}CI excludes zero: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{ci\PYGZus{}excludes\PYGZus{}zero}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{\PYGZdq{}}
    \PYG{p}{)}

    \PYG{k}{return} \PYG{n}{GateResult}\PYG{p}{(}
        \PYG{n}{passed}\PYG{o}{=}\PYG{n}{passed}\PYG{p}{,}
        \PYG{n}{metric\PYGZus{}name}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}groundedness\PYGZdq{}}\PYG{p}{,}
        \PYG{n}{baseline\PYGZus{}mean}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}scores}\PYG{p}{),}
        \PYG{n}{candidate\PYGZus{}mean}\PYG{o}{=}\PYG{n}{np}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{candidate\PYGZus{}scores}\PYG{p}{),}
        \PYG{n}{improvement}\PYG{o}{=}\PYG{n}{mean\PYGZus{}diff}\PYG{p}{,}
        \PYG{n}{confidence\PYGZus{}interval}\PYG{o}{=}\PYG{p}{(}\PYG{n}{lower\PYGZus{}bound}\PYG{p}{,} \PYG{n}{upper\PYGZus{}bound}\PYG{p}{),}
        \PYG{n}{p\PYGZus{}value}\PYG{o}{=}\PYG{k+kc}{None}\PYG{p}{,}  \PYG{c+c1}{\PYGZsh{} Bootstrap doesn\PYGZsq{}t provide p\PYGZhy{}value}
        \PYG{n}{message}\PYG{o}{=}\PYG{n}{message}
    \PYG{p}{)}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{mcnemar\PYGZus{}test}\PYG{p}{(}
    \PYG{n}{baseline\PYGZus{}flags}\PYG{p}{:} \PYG{n}{List}\PYG{p}{[}\PYG{n+nb}{bool}\PYG{p}{],}
    \PYG{n}{candidate\PYGZus{}flags}\PYG{p}{:} \PYG{n}{List}\PYG{p}{[}\PYG{n+nb}{bool}\PYG{p}{],}
    \PYG{n}{alpha}\PYG{p}{:} \PYG{n+nb}{float} \PYG{o}{=} \PYG{l+m+mf}{0.05}
\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{GateResult}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    McNemar\PYGZsq{}s test for binary metrics (e.g., toxicity flags).}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        baseline\PYGZus{}flags: Binary flags from baseline (True = violation)}
\PYG{l+s+sd}{        candidate\PYGZus{}flags: Binary flags from candidate}
\PYG{l+s+sd}{        alpha: Significance level}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{        GateResult indicating whether gate passed}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{k}{if} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{)} \PYG{o}{!=} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{candidate\PYGZus{}flags}\PYG{p}{):}
        \PYG{k}{raise} \PYG{n+ne}{ValueError}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Baseline and candidate must have same length\PYGZdq{}}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Contingency table}
    \PYG{n}{both\PYGZus{}negative} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}
        \PYG{p}{(}\PYG{o+ow}{not} \PYG{n}{b}\PYG{p}{)} \PYG{o+ow}{and} \PYG{p}{(}\PYG{o+ow}{not} \PYG{n}{c}\PYG{p}{)}
        \PYG{k}{for} \PYG{n}{b}\PYG{p}{,} \PYG{n}{c} \PYG{o+ow}{in} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{,} \PYG{n}{candidate\PYGZus{}flags}\PYG{p}{)}
    \PYG{p}{)}
    \PYG{n}{baseline\PYGZus{}positive} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}
        \PYG{n}{b} \PYG{o+ow}{and} \PYG{p}{(}\PYG{o+ow}{not} \PYG{n}{c}\PYG{p}{)}
        \PYG{k}{for} \PYG{n}{b}\PYG{p}{,} \PYG{n}{c} \PYG{o+ow}{in} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{,} \PYG{n}{candidate\PYGZus{}flags}\PYG{p}{)}
    \PYG{p}{)}
    \PYG{n}{candidate\PYGZus{}positive} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}
        \PYG{p}{(}\PYG{o+ow}{not} \PYG{n}{b}\PYG{p}{)} \PYG{o+ow}{and} \PYG{n}{c}
        \PYG{k}{for} \PYG{n}{b}\PYG{p}{,} \PYG{n}{c} \PYG{o+ow}{in} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{,} \PYG{n}{candidate\PYGZus{}flags}\PYG{p}{)}
    \PYG{p}{)}
    \PYG{n}{both\PYGZus{}positive} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}
        \PYG{n}{b} \PYG{o+ow}{and} \PYG{n}{c}
        \PYG{k}{for} \PYG{n}{b}\PYG{p}{,} \PYG{n}{c} \PYG{o+ow}{in} \PYG{n+nb}{zip}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{,} \PYG{n}{candidate\PYGZus{}flags}\PYG{p}{)}
    \PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} McNemar\PYGZsq{}s test (discordant pairs only)}
    \PYG{n}{contingency} \PYG{o}{=} \PYG{p}{[[}\PYG{n}{both\PYGZus{}negative}\PYG{p}{,} \PYG{n}{baseline\PYGZus{}positive}\PYG{p}{],}
                   \PYG{p}{[}\PYG{n}{candidate\PYGZus{}positive}\PYG{p}{,} \PYG{n}{both\PYGZus{}positive}\PYG{p}{]]}

    \PYG{c+c1}{\PYGZsh{} Calculate statistic}
    \PYG{n}{b} \PYG{o}{=} \PYG{n}{baseline\PYGZus{}positive}
    \PYG{n}{c} \PYG{o}{=} \PYG{n}{candidate\PYGZus{}positive}

    \PYG{k}{if} \PYG{n}{b} \PYG{o}{+} \PYG{n}{c} \PYG{o}{==} \PYG{l+m+mi}{0}\PYG{p}{:}
        \PYG{c+c1}{\PYGZsh{} No discordant pairs \PYGZhy{} no change}
        \PYG{n}{p\PYGZus{}value} \PYG{o}{=} \PYG{l+m+mf}{1.0}
        \PYG{n}{passed} \PYG{o}{=} \PYG{k+kc}{True}
    \PYG{k}{else}\PYG{p}{:}
        \PYG{c+c1}{\PYGZsh{} McNemar\PYGZsq{}s chi\PYGZhy{}squared statistic}
        \PYG{n}{chi2} \PYG{o}{=} \PYG{p}{((}\PYG{n}{b} \PYG{o}{\PYGZhy{}} \PYG{n}{c}\PYG{p}{)} \PYG{o}{**} \PYG{l+m+mi}{2}\PYG{p}{)} \PYG{o}{/} \PYG{p}{(}\PYG{n}{b} \PYG{o}{+} \PYG{n}{c}\PYG{p}{)}
        \PYG{n}{p\PYGZus{}value} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{stats}\PYG{o}{.}\PYG{n}{chi2}\PYG{o}{.}\PYG{n}{cdf}\PYG{p}{(}\PYG{n}{chi2}\PYG{p}{,} \PYG{n}{df}\PYG{o}{=}\PYG{l+m+mi}{1}\PYG{p}{)}

        \PYG{c+c1}{\PYGZsh{} Gate: must not increase (candidate\PYGZus{}positive \PYGZlt{}= baseline\PYGZus{}positive)}
        \PYG{c+c1}{\PYGZsh{} AND p\PYGZhy{}value must be \PYGZgt{} alpha (not significantly worse)}
        \PYG{n}{passed} \PYG{o}{=} \PYG{p}{(}\PYG{n}{candidate\PYGZus{}positive} \PYG{o}{\PYGZlt{}=} \PYG{n}{baseline\PYGZus{}positive}\PYG{p}{)} \PYG{o+ow}{and} \PYG{p}{(}\PYG{n}{p\PYGZus{}value} \PYG{o}{\PYGZgt{}} \PYG{n}{alpha}\PYG{p}{)}

    \PYG{n}{baseline\PYGZus{}rate} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{)} \PYG{o}{/} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{baseline\PYGZus{}flags}\PYG{p}{)}
    \PYG{n}{candidate\PYGZus{}rate} \PYG{o}{=} \PYG{n+nb}{sum}\PYG{p}{(}\PYG{n}{candidate\PYGZus{}flags}\PYG{p}{)} \PYG{o}{/} \PYG{n+nb}{len}\PYG{p}{(}\PYG{n}{candidate\PYGZus{}flags}\PYG{p}{)}

    \PYG{n}{message} \PYG{o}{=} \PYG{p}{(}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Baseline violation rate: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{baseline\PYGZus{}rate}\PYG{l+s+si}{:}\PYG{l+s+s2}{.3f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{, \PYGZdq{}}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Candidate: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{candidate\PYGZus{}rate}\PYG{l+s+si}{:}\PYG{l+s+s2}{.3f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{. \PYGZdq{}}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}McNemar p\PYGZhy{}value: }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{p\PYGZus{}value}\PYG{l+s+si}{:}\PYG{l+s+s2}{.4f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{. \PYGZdq{}}
        \PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}Required: no increase (p \PYGZgt{} }\PYG{l+s+si}{\PYGZob{}}\PYG{n}{alpha}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{)\PYGZdq{}}
    \PYG{p}{)}

    \PYG{k}{return} \PYG{n}{GateResult}\PYG{p}{(}
        \PYG{n}{passed}\PYG{o}{=}\PYG{n}{passed}\PYG{p}{,}
        \PYG{n}{metric\PYGZus{}name}\PYG{o}{=}\PYG{l+s+s2}{\PYGZdq{}toxicity\PYGZdq{}}\PYG{p}{,}
        \PYG{n}{baseline\PYGZus{}mean}\PYG{o}{=}\PYG{n}{baseline\PYGZus{}rate}\PYG{p}{,}
        \PYG{n}{candidate\PYGZus{}mean}\PYG{o}{=}\PYG{n}{candidate\PYGZus{}rate}\PYG{p}{,}
        \PYG{n}{improvement}\PYG{o}{=}\PYG{n}{baseline\PYGZus{}rate} \PYG{o}{\PYGZhy{}} \PYG{n}{candidate\PYGZus{}rate}\PYG{p}{,}
        \PYG{n}{confidence\PYGZus{}interval}\PYG{o}{=}\PYG{k+kc}{None}\PYG{p}{,}
        \PYG{n}{p\PYGZus{}value}\PYG{o}{=}\PYG{n}{p\PYGZus{}value}\PYG{p}{,}
        \PYG{n}{message}\PYG{o}{=}\PYG{n}{message}
    \PYG{p}{)}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{evaluate\PYGZus{}ci\PYGZus{}gate}\PYG{p}{(}
    \PYG{n}{metrics}\PYG{p}{:} \PYG{n}{Dict}\PYG{p}{[}\PYG{n+nb}{str}\PYG{p}{,} \PYG{n}{Dict}\PYG{p}{],}
    \PYG{n}{config}\PYG{p}{:} \PYG{n}{Optional}\PYG{p}{[}\PYG{n}{Dict}\PYG{p}{]} \PYG{o}{=} \PYG{k+kc}{None}
\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{Dict}\PYG{p}{[}\PYG{n+nb}{str}\PYG{p}{,} \PYG{n}{GateResult}\PYG{p}{]:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Evaluate multiple CI gates with configurable metric types.}

\PYG{l+s+sd}{    Supports three metric comparison modes:}
\PYG{l+s+sd}{      \PYGZhy{} \PYGZdq{}exact\PYGZus{}match\PYGZdq{}: binary pass/fail per example}
\PYG{l+s+sd}{      \PYGZhy{} \PYGZdq{}fuzzy\PYGZus{}match\PYGZdq{}: continuous scores with bootstrap}
\PYG{l+s+sd}{      \PYGZhy{} \PYGZdq{}semantic\PYGZus{}similarity\PYGZdq{}: embedding\PYGZhy{}based comparison}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        metrics: Dict mapping metric names to their data:}
\PYG{l+s+sd}{            \PYGZob{}}
\PYG{l+s+sd}{              \PYGZdq{}groundedness\PYGZdq{}: \PYGZob{}}
