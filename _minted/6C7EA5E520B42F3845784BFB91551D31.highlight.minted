    \PYG{k}{for} \PYG{n}{name}\PYG{p}{,} \PYG{n}{result} \PYG{o+ow}{in} \PYG{n}{results\PYGZus{}100}\PYG{o}{.}\PYG{n}{items}\PYG{p}{():}
        \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+sa}{f}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{name}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{: \PYGZdl{}}\PYG{l+s+si}{\PYGZob{}}\PYG{n}{result}\PYG{o}{.}\PYG{n}{cost\PYGZus{}per\PYGZus{}1k\PYGZus{}tokens\PYGZus{}usd}\PYG{l+s+si}{:}\PYG{l+s+s2}{.4f}\PYG{l+s+si}{\PYGZcb{}}\PYG{l+s+s2}{ per 1k tokens\PYGZdq{}}\PYG{p}{)}

    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+se}{\PYGZbs{}n}\PYG{l+s+s2}{Cost comparison at 50}\PYG{l+s+si}{\PYGZpc{} u}\PYG{l+s+s2}{tilization:\PYGZdq{}}\PYG{p}{)}
    \PYG{n}{results\PYGZus{}50} \PYG{o}{=} \PYG{n}{compare\PYGZus{}gpu\PYGZus{}options}\PYG{p}{([}\PYG{n}{a100\PYGZus{}80gb}\PYG{p}{,} \PYG{n}{h100\PYGZus{}80gb}\PYG{p}{],} \PYG{l+m+mf}{50.0}\PYG{p}{)}
