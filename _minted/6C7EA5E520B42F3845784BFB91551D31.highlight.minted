    \PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Cost per second}
    \PYG{n}{cost\PYGZus{}per\PYGZus{}second} \PYG{o}{=} \PYG{n}{gpu}\PYG{o}{.}\PYG{n}{hourly\PYGZus{}cost\PYGZus{}usd} \PYG{o}{/} \PYG{l+m+mf}{3600.0}

    \PYG{c+c1}{\PYGZsh{} Cost per token}
    \PYG{n}{cost\PYGZus{}per\PYGZus{}token} \PYG{o}{=} \PYG{n}{cost\PYGZus{}per\PYGZus{}second} \PYG{o}{/} \PYG{n}{effective\PYGZus{}throughput}

    \PYG{c+c1}{\PYGZsh{} Cost per 1k tokens}
    \PYG{n}{cost\PYGZus{}per\PYGZus{}1k\PYGZus{}tokens} \PYG{o}{=} \PYG{n}{cost\PYGZus{}per\PYGZus{}token} \PYG{o}{*} \PYG{l+m+mf}{1000.0}

    \PYG{k}{return} \PYG{n}{CostResult}\PYG{p}{(}
        \PYG{n}{cost\PYGZus{}per\PYGZus{}1k\PYGZus{}tokens\PYGZus{}usd}\PYG{o}{=}\PYG{n}{cost\PYGZus{}per\PYGZus{}1k\PYGZus{}tokens}\PYG{p}{,}
