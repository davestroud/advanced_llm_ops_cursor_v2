        \PYG{n}{effective\PYGZus{}throughput\PYGZus{}tokens\PYGZus{}per\PYGZus{}sec}\PYG{o}{=}\PYG{n}{effective\PYGZus{}throughput}\PYG{p}{,}
        \PYG{n}{utilization\PYGZus{}percent}\PYG{o}{=}\PYG{n}{utilization\PYGZus{}percent}
    \PYG{p}{)}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{compare\PYGZus{}gpu\PYGZus{}options}\PYG{p}{(}
    \PYG{n}{gpus}\PYG{p}{:} \PYG{n+nb}{list}\PYG{p}{[}\PYG{n}{GPUConfig}\PYG{p}{],}
    \PYG{n}{utilization\PYGZus{}percent}\PYG{p}{:} \PYG{n+nb}{float} \PYG{o}{=} \PYG{l+m+mf}{100.0}
\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n+nb}{dict}\PYG{p}{[}\PYG{n+nb}{str}\PYG{p}{,} \PYG{n}{CostResult}\PYG{p}{]:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Compare cost across multiple GPU options.}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        gpus: List of GPU configurations}
\PYG{l+s+sd}{        utilization\PYGZus{}percent: Utilization to compare at}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{        Dictionary mapping GPU name to CostResult}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{results} \PYG{o}{=} \PYG{p}{\PYGZob{}\PYGZcb{}}
    \PYG{k}{for} \PYG{n}{gpu} \PYG{o+ow}{in} \PYG{n}{gpus}\PYG{p}{:}
        \PYG{n}{results}\PYG{p}{[}\PYG{n}{gpu}\PYG{o}{.}\PYG{n}{name}\PYG{p}{]} \PYG{o}{=} \PYG{n}{calculate\PYGZus{}cost\PYGZus{}per\PYGZus{}token}\PYG{p}{(}
            \PYG{n}{gpu}\PYG{p}{,} \PYG{n}{utilization\PYGZus{}percent}
        \PYG{p}{)}
    \PYG{k}{return} \PYG{n}{results}

\PYG{c+c1}{\PYGZsh{} Example usage}
\PYG{k}{if} \PYG{n+nv+vm}{\PYGZus{}\PYGZus{}name\PYGZus{}\PYGZus{}} \PYG{o}{==} \PYG{l+s+s2}{\PYGZdq{}\PYGZus{}\PYGZus{}main\PYGZus{}\PYGZus{}\PYGZdq{}}\PYG{p}{:}
    \PYG{c+c1}{\PYGZsh{} Define GPU configurations}
