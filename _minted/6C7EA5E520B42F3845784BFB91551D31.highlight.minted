\PYG{n+nd}{@dataclass}
\PYG{k}{class}\PYG{+w}{ }\PYG{n+nc}{CostResult}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}Cost calculation result\PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{n}{cost\PYGZus{}per\PYGZus{}1k\PYGZus{}tokens\PYGZus{}usd}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{cost\PYGZus{}per\PYGZus{}second\PYGZus{}usd}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{effective\PYGZus{}throughput\PYGZus{}tokens\PYGZus{}per\PYGZus{}sec}\PYG{p}{:} \PYG{n+nb}{float}
    \PYG{n}{utilization\PYGZus{}percent}\PYG{p}{:} \PYG{n+nb}{float}

\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{calculate\PYGZus{}cost\PYGZus{}per\PYGZus{}token}\PYG{p}{(}
    \PYG{n}{gpu}\PYG{p}{:} \PYG{n}{GPUConfig}\PYG{p}{,}
    \PYG{n}{utilization\PYGZus{}percent}\PYG{p}{:} \PYG{n+nb}{float} \PYG{o}{=} \PYG{l+m+mf}{100.0}\PYG{p}{,}
    \PYG{n}{tokens\PYGZus{}per\PYGZus{}request}\PYG{p}{:} \PYG{n}{Optional}\PYG{p}{[}\PYG{n+nb}{int}\PYG{p}{]} \PYG{o}{=} \PYG{k+kc}{None}
\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{CostResult}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Calculate cost per token based on GPU utilization.}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        gpu: GPU configuration}
\PYG{l+s+sd}{        utilization\PYGZus{}percent: GPU utilization (0\PYGZhy{}100)}
\PYG{l+s+sd}{        tokens\PYGZus{}per\PYGZus{}request: Optional average tokens per request}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{        CostResult with cost metrics}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{k}{if} \PYG{o+ow}{not} \PYG{l+m+mi}{0} \PYG{o}{\PYGZlt{}=} \PYG{n}{utilization\PYGZus{}percent} \PYG{o}{\PYGZlt{}=} \PYG{l+m+mi}{100}\PYG{p}{:}
        \PYG{k}{raise} \PYG{n+ne}{ValueError}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Utilization must be between 0 and 100\PYGZdq{}}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Effective throughput scales with utilization}
    \PYG{n}{effective\PYGZus{}throughput} \PYG{o}{=} \PYG{p}{(}
