    \PYG{c+c1}{\PYGZsh{} Compare at different utilization levels}
    \PYG{n+nb}{print}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}Cost comparison at 100}\PYG{l+s+si}{\PYGZpc{} u}\PYG{l+s+s2}{tilization:\PYGZdq{}}\PYG{p}{)}
